# ── Rambler 3.0 — Environment Configuration ──────────────────

# Backend: "fireworks" (cloud API) or "local" (vLLM on AMD GPU)
INFERENCE_BACKEND=fireworks

# Fireworks AI API Key (required when INFERENCE_BACKEND=fireworks)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Local vLLM URL (required when INFERENCE_BACKEND=local)
LOCAL_API_URL=http://localhost:8080/v1/chat/completions

# Optional: Override model IDs
# PERCEPTION_MODEL=accounts/fireworks/models/gemma-4-31b-it
# STYLING_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
# EVAL_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
